PORT=8080
DATABASE_URL=postgres://your_user@localhost:5432/studyos
PG_SSL=false
PG_POOL_MAX=20
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:8080/auth/callback
GOOGLE_OAUTH_SUCCESS_REDIRECT=studyos://oauth-success
GOOGLE_OAUTH_FAILURE_REDIRECT=studyos://oauth-failure
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_CLIENT_EMAIL=your_firebase_client_email
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nyour_firebase_private_key\n-----END PRIVATE KEY-----\n"
OAUTH_STATE_TTL_MS=600000
IMPORT_RATE_LIMIT_MAX=10
IMPORT_RATE_LIMIT_WINDOW_MS=60000
